# =============================================
# TRUSTLEDGER BACKEND - ENVIRONMENT VARIABLES
# =============================================

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=https://trust-ledger-alpha.vercel.app

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/trustledger?retryWrites=true&w=majority

# JWT Secrets
JWT_SECRET=your_super_secret_jwt_key_minimum_64_characters_long_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_also_64_chars_minimum
JWT_REFRESH_EXPIRE=30d

# Encryption (AES-256 — must be exactly 32 chars)
ENCRYPTION_KEY=your_32_char_encryption_key_here!
ENCRYPTION_SALT=your_random_salt_value_here_12345

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Email (Nodemailer - SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@trustledger.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=TrustLedger <noreply@trustledger.com>

# Twilio (SMS / OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Cloudinary (ID photos / selfies)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI Face Matching (AWS Rekognition)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Stripe (Payment Gateway)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Public Verification Portal
VERIFICATION_PORTAL_URL=https://verify.trustledger.com

# OTP Settings
OTP_EXPIRE_MINUTES=10
OTP_LINK_EXPIRE_HOURS=24

# Trust Score AI
TRUST_SCORE_RECALCULATE_THRESHOLD=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
