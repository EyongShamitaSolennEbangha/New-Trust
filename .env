# =============================================
# TRUSTLEDGER BACKEND - ENVIRONMENT VARIABLES
# =============================================

# ──── SERVER ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ──── MONGODB (Required) ─────────────────────────────────────────────────────
# Local MongoDB is installed and running on this machine.
MONGO_URI=mongodb://127.0.0.1:27017/trustledger

# ──── JWT SECRETS (Required) ─────────────────────────────────────────────────
# Generate random 64+ char strings: https://generate-random.org/ or use openssl
# openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_minimum_64_characters_long_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_also_64_chars_minimum_64_chars_required
JWT_REFRESH_EXPIRE=30d

# ──── ENCRYPTION (Required) ──────────────────────────────────────────────────
# ENCRYPTION_KEY: Exactly 32 characters (use: head -c 32 /dev/urandom | base64)
# ENCRYPTION_SALT: Random string for additional security
ENCRYPTION_KEY=32_char_key_abcdefghijklmnopqrst
ENCRYPTION_SALT=your_random_salt_value_here_12345

# ──── REDIS (Required for caching, token blacklist, OTP) ────────────────────
# Local: Use defaults below
# Cloud: Get from https://redis.com (free tier 30MB available)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ──── EMAIL (For email verification & password reset) ───────────────────────
# Gmail: Requires APP PASSWORD (not regular password)
# 1. Enable 2FA on Google Account
# 2. Go to myaccount.google.com/apppasswords
# 3. Select "Mail" & "Windows Computer"
# 4. Copy the 16-char app password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=TrustLedger <noreply@trustledger.com>

# ──── TWILIO (For SMS/OTP - optional but recommended) ──────────────────────
# Get from: https://www.twilio.com (free trial with $15 credit)
# 1. Create account
# 2. Get ACCOUNT_SID & AUTH_TOKEN from dashboard
# 3. Verify your phone number
TWILIO_ACCOUNT_SID=AC_your_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1_your_twilio_number

# ──── CLOUDINARY (For image uploads - optional) ──────────────────────────────
# Get from: https://cloudinary.com (free tier: 10GB storage, 2GB bandwidth)
# 1. Sign up
# 2. Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=dpvpk75mn
CLOUDINARY_API_KEY=481742918215221
CLOUDINARY_API_SECRET=GuGpVbk3MTOOtC_8ji8pFqR60yw

# ──── AWS REKOGNITION (For face matching - optional but recommended) ────────
# Get from: https://aws.amazon.com (free tier: 5,000 API calls/month)
# 1. Create AWS Account
# 2. IAM → Create User → Attach "AmazonRekognitionFullAccess"
# 3. Create Access Keys
# AWS_ACCESS_KEY_ID=AKIA_your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_REGION=us-east-1

# ──── STRIPE (For payments - optional) ────────────────────────────────────
# Get from: https://stripe.com (free account, live keys available)
# 1. Sign up
# 2. API Keys → Copy Secret Key & Webhook Signing Secret
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ──── VERIFICATION & OTP ─────────────────────────────────────────────────────
VERIFICATION_PORTAL_URL=https://verify.trustledger.com
OTP_EXPIRE_MINUTES=10
OTP_LINK_EXPIRE_HOURS=24

# ──── TRUST SCORE ────────────────────────────────────────────────────────────
TRUST_SCORE_RECALCULATE_THRESHOLD=5

# ──── RATE LIMITING ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
